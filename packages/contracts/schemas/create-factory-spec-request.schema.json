{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atrielle.io/aurim/contracts/schemas/create-factory-spec-request.schema.json",
  "title": "CreateFactorySpecRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "problem_statement",
    "goal",
    "non_negotiable_constraints",
    "initial_scope",
    "acceptance_standard",
    "created_by"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "non_negotiable_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "initial_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "excluded_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_standard": {
      "type": "string",
      "minLength": 1
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    }
  }
}
