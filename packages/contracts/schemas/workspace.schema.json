{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atrielle.io/aurim/contracts/schemas/workspace.schema.json",
  "title": "Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace_id",
    "slug",
    "name",
    "status",
    "created_at",
    "created_by",
    "updated_at"
  ],
  "properties": {
    "workspace_id": {
      "type": "string",
      "format": "uuid"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived", "deleted"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
