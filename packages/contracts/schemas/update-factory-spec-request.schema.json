{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atrielle.io/aurim/contracts/schemas/update-factory-spec-request.schema.json",
  "title": "UpdateFactorySpecRequest",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "non_negotiable_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "initial_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "excluded_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_standard": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved", "superseded"]
    }
  }
}
