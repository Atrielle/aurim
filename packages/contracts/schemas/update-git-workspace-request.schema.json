{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atrielle.io/aurim/contracts/schemas/update-git-workspace-request.schema.json",
  "title": "UpdateGitWorkspaceRequest",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "default_branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "connection_status": {
      "type": "string",
      "enum": ["connected", "disconnected", "error", "archived"]
    }
  }
}
