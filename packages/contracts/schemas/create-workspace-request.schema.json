{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atrielle.io/aurim/contracts/schemas/create-workspace-request.schema.json",
  "title": "CreateWorkspaceRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["slug", "name", "created_by"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    }
  }
}
