{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atrielle.io/aurim/contracts/schemas/create-factory-run-request.schema.json",
  "title": "CreateFactoryRunRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace_id",
    "factory_spec_id",
    "planner_prompt_ref",
    "generator_prompt_ref",
    "evaluator_prompt_ref",
    "contract_snapshot_ref",
    "artifact_root_ref",
    "created_by"
  ],
  "properties": {
    "workspace_id": {
      "type": "string",
      "format": "uuid"
    },
    "factory_spec_id": {
      "type": "string",
      "format": "uuid"
    },
    "planner_prompt_ref": {
      "type": "string",
      "minLength": 1
    },
    "generator_prompt_ref": {
      "type": "string",
      "minLength": 1
    },
    "evaluator_prompt_ref": {
      "type": "string",
      "minLength": 1
    },
    "contract_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_root_ref": {
      "type": "string",
      "minLength": 1
    },
    "touched_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    }
  }
}
